# Database (optional — defaults to SQLite at data/autoresearch.db)
# Set to a PostgreSQL connection string for production (e.g. Neon, RDS)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# SQS (optional — only needed for AWS worker deployment)
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/autoresearch-jobs
# AWS_REGION=us-east-1
